# Supabase Configuration - Free (desarrollo/certificacion)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key
NEXT_SUPABASE_SECRET_KEY=sb_secret_your-secret-key

# Supabase Pro (production)
SUPABASE_PRO_URL=https://your-pro-project-id.supabase.co
SUPABASE_PRO_PROJECT_REF=your-pro-project-ref
SUPABASE_MGMT_TOKEN=your-management-api-token

# Note: Get these from Supabase Dashboard > Settings > API
# NEVER commit real credentials to the repository